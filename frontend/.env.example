NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_CONTRACT_ID=

# ─── Stellar Network ─────────────────────────────────────────────────────────
# "TESTNET" or "MAINNET"
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET

# Soroban RPC endpoint (Testnet)
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Horizon endpoint (Testnet)
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# ─── Soroban Escrow Contract ──────────────────────────────────────────────────
# The contract ID (C... address) of the deployed escrow contract.
# Run `stellar contract deploy` and paste the returned contract address here.
NEXT_PUBLIC_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Backend API ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000